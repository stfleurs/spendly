rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---

    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function immutable(field) {
      return !(field in request.resource.data) || request.resource.data[field] == resource.data[field];
    }

    // --- RULES ---

    // Users collection and sub-collections
    match /users/{userId} {
      allow read, write: if isOwner(userId);

      match /categories/{catId} {
        allow read, write: if isOwner(userId);
      }

      match /bills/{billId} {
        // Temporary relaxation to diagnose PERMISSION_DENIED
        allow read, write: if signedIn();
      }

      match /bill_templates/{templateId} {
        allow read, write: if signedIn();
      }

      match /monthly_summaries/{summaryId} {
        allow read, write: if isOwner(userId);
      }

      match /merchant_preferences/{prefId} {
        allow read, write: if isOwner(userId);
      }

      match /financial_summary/{doc} {
        allow read, write: if isOwner(userId);
      }

      match /daily_net_worth/{doc} {
        allow read, write: if isOwner(userId);
      }

      match /allocations/{allocId} {
        allow read, write: if isOwner(userId);
      }

      // Receipt learning data
      match /receipt_learning/{version} {
        allow read, write: if isOwner(userId);
        
        match /{allPaths=**} {
          allow read, write: if isOwner(userId);
        }
      }
    }

    // --- GLOBAL LEARNING (Shared Intelligence) ---
    
    // Curated global intelligence (Read-only for users, updated by Cloud Functions)
    match /global_learning/{version} {
      allow read: if signedIn();
      allow write: if false;

      match /{allPaths=**} {
        allow read: if signedIn();
        allow write: if false;
      }
    }

    // User contributions to global learning (Anonymized, Create-only)
    match /global_contributions_v1/{docId} {
      allow create: if signedIn() 
        && request.resource.data.userId == request.auth.uid; // Track source for anti-spam, but keep data anonymized
      allow read, update, delete: if false;
    }

    match /transactions/{txId} {
      // List queries are filtered by userId in the app; resource is null on queries so we can't check it.
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.userId == request.auth.uid;
    }

    match /accounts/{accId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.userId == request.auth.uid;
    }

    match /receipts/{rcptId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.userId == request.auth.uid;
    }

    // Default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
